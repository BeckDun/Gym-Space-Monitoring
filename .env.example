# Copy to .env and fill in values
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL (used when Docker is running)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/gsm

# SQLite fallback (default when PostgreSQL is not available)
# DATABASE_URL=sqlite:///./gsm.db

# Set to 1 to skip real Gemini calls and use mock MLLM output
# USE_MOCK_MLLM=0
